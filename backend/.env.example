# Copy to backend/.env and fill in values for local development.
# Loaded via godotenv at startup; never commit the real .env file.

APP_ENV=local

# Operational overrides (optional — defaults come from config/*.yaml)
# APP_SERVER_HOST=0.0.0.0
# APP_SERVER_PORT=8080
# APP_LOG_LEVEL=debug
# APP_LOG_FORMAT=console

# Secrets (only needed when mongo/redis are enabled in config/*.yaml)
# APP_MONGO_URI=mongodb://localhost:27017/omnirouter
# APP_REDIS_ADDR=localhost:6379
# APP_REDIS_PASSWORD=
